generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id             String   @id @default(cuid())
  title_en       String
  title_es       String
  description_en String?  @db.Text
  description_es String?  @db.Text
  images         String   @default("[]") @db.Text
  projectType    String?  @default("web")
  techStack      String   @default("[]") @db.Text
  githubUrl      String?
  liveUrl        String?
  client         String?
  year           Int?
  featured       Boolean  @default(false)
  visible        Boolean  @default(true)
  order          Int      @default(0)
  tags           String   @default("[]") @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Service {
  id             String   @id @default(cuid())
  title_en       String
  title_es       String
  description_en String?  @db.Text
  description_es String?  @db.Text
  icon           String?
  image          String?
  visible        Boolean  @default(true)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Quote {
  id          String   @id @default(cuid())
  name        String
  email       String
  company     String?
  projectType String?  @default("web")
  description String   @db.Text
  budget      String?
  timeline    String?
  techStack   String?
  status      String   @default("pendiente")
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Invoice {
  id          String   @id @default(cuid())
  number      String
  clientName  String
  clientEmail String?
  concept     String   @db.Text
  amount      Float    @default(0)
  currency    String   @default("MXN")
  status      String   @default("borrador")
  dueDate     String?
  issuedAt    String?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Appointment {
  id        String   @id @default(cuid())
  name      String
  email     String
  date      String
  time      String?
  topic     String
  notes     String?  @db.Text
  status    String   @default("pendiente")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// CMS: key-value store for editable landing page content
model SiteContent {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// Dynamic clients section
model ClientLogo {
  id        String   @id @default(cuid())
  name      String
  logo      String?
  url       String?
  visible   Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
