# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/mezadigital"

# JWT signing secret — genera uno largo y aleatorio en producción
JWT_SECRET="change-this-to-a-long-random-string-min-32-chars"

# Admin credentials
ADMIN_EMAIL="admin@mezadigital.com"
ADMIN_PASSWORD="your-secure-password-here"
